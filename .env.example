# ============================================================
# .env.example — Banking Data Platform environment variables
# ============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# .env is gitignored — never commit real credentials.
# ============================================================

# ── dbt target ─────────────────────────────────────────────
# local  → DuckDB + MinIO  (default, no cloud creds needed)
# dev    → Snowflake DEV
# prod   → Snowflake PROD
DBT_TARGET=local

# ── MinIO (local S3) ───────────────────────────────────────
# Change these in production or if MinIO is exposed externally.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Override if MinIO is not running on the same compose network:
# AWS_ENDPOINT_URL_S3=http://minio:9000

# ── Spark ──────────────────────────────────────────────────
# Number of CPU cores and RAM for the local Spark worker.
SPARK_WORKER_CORES=2
SPARK_WORKER_MEMORY=2G

# ── Airflow ────────────────────────────────────────────────
# UID of the host user so volume-mounted files are not owned by root.
# Run: echo "AIRFLOW_UID=$(id -u)" >> .env
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# ── AWS (cloud mode only — set DBT_TARGET=dev or prod) ─────
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Snowflake (cloud mode only) ────────────────────────────
# SNOWFLAKE_ACCOUNT=<orgname>-<account>
# SNOWFLAKE_USER=
# SNOWFLAKE_PASSWORD=
# SNOWFLAKE_ROLE=TRANSFORMER
# SNOWFLAKE_DATABASE=ANALYTICS

# ── DuckDB UI (local web service) ──────────────────────────
# Optional Basic Auth for http://localhost:4213/
DUCKDB_UI_USERNAME=admin
DUCKDB_UI_PASSWORD=change-me

# Query controls
DUCKDB_UI_MAX_ROWS=200
DUCKDB_UI_QUERY_TIMEOUT_MS=10000

# Optional token for non-local /health checks.
# Local health checks inside the container do not require this.
# DUCKDB_UI_HEALTH_TOKEN=
