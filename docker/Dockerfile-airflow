
# ============================================================
# Dockerfile-airflow.dockerfile — Airflow image
# ============================================================
# Extends the official apache/airflow base image.
# Extra packages are installed into the BASE image's Python
# via pip + official Airflow constraints.
# Do NOT create a separate venv — it shadows base packages
# and breaks flask_session, migrations, and other internals.
# ============================================================
FROM apache/airflow:2.8.1-python3.11

USER root

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        gcc \
        g++ \
        libpq-dev \
        procps \
        default-jre-headless \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

USER airflow

# Official constraints pin every transitive dep to a known-good set.
# Always use constraints when extending the Airflow base image.
ARG AIRFLOW_VERSION=2.8.1
ARG PYTHON_VERSION=3.11
ARG CONSTRAINTS_URL="https://raw.githubusercontent.com/apache/airflow/constraints-${AIRFLOW_VERSION}/constraints-${PYTHON_VERSION}.txt"

RUN pip install --no-cache-dir \
    --constraint "${CONSTRAINTS_URL}" \
    "apache-airflow-providers-amazon==8.16.0" \
    "apache-airflow-providers-docker==3.9.1" \
    "apache-airflow-providers-snowflake==5.2.1" \
    "apache-airflow-providers-apache-spark==4.7.0" \
    "psycopg2-binary==2.9.9"

# Install DuckDB separately (without Airflow constraints) to keep
# compatibility with the existing local warehouse file format.
RUN pip install --no-cache-dir "duckdb==1.1.3"

# Copy DAGs and dbt project into AIRFLOW_HOME
# (also volume-mounted at runtime for hot-reload in local dev)
COPY --chown=airflow:root dags/ ${AIRFLOW_HOME}/dags/
COPY --chown=airflow:root dbt/ ${AIRFLOW_HOME}/dbt/

ENV AIRFLOW__CORE__LOAD_EXAMPLES=False \
    AIRFLOW__CORE__DAGS_FOLDER=${AIRFLOW_HOME}/dags
