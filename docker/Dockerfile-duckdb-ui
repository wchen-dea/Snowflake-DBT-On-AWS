FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
	PYTHONUNBUFFERED=1 \
	DUCKDB_PATH=/opt/dbt/warehouse/banking_vault.duckdb \
	APP_PORT=4213

RUN apt-get update && \
	apt-get install -y --no-install-recommends curl && \
	apt-get clean && \
	rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir flask==3.0.3 duckdb==1.1.3

WORKDIR /app
COPY docker/duckdb_ui_server.py /app/server.py

EXPOSE 4213

CMD ["python", "/app/server.py"]
